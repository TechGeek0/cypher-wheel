# ─────────────────────────────────────────────────────
# CYPHER WHEEL — Backend config template
# Copy this file to .env and fill in real values.
# NEVER commit .env — it contains your private key.
# ─────────────────────────────────────────────────────

# ── RPC ───────────────────────────────────────────────
# Helius RPC endpoint (helius.dev — free tier works).
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Token ─────────────────────────────────────────────
# Pump.fun token mint address — paste after launch.
TOKEN_MINT=YOUR_TOKEN_MINT_ADDRESS

# ── Prize pool wallet ─────────────────────────────────
# This wallet receives Pump.fun creator fees and pays out winners.
# Export the base58 private key from Phantom (Settings → Export private key).
# KEEP THIS SECRET — anyone with this key owns the wallet.
POOL_WALLET_SECRET=YOUR_BASE58_SECRET_KEY

# ── Exclusion list ────────────────────────────────────
# Wallets that must never win or count as holders.
# Add: bonding curve address, your dev wallet, any CEX wallets.
# The pool wallet itself is excluded automatically.
EXCLUDED_ADDRESSES=

# ── Raffle config ─────────────────────────────────────
# Seconds between spins (300 = every 5 minutes).
ROUND_INTERVAL_SECONDS=300

# Minimum token balance to qualify for a ticket.
MIN_BALANCE=1000

# Ticket weighting: "sqrt" (recommended) | "linear"
WEIGHTING=sqrt

# % of the SOL pot used for buyback + burn before paying winner.
BUYBACK_PERCENT=50

# What happens to bought-back tokens.
BUYBACK_MODE=burn

# ── Safety ────────────────────────────────────────────
# true  → simulate everything, move NO real funds. START HERE.
# false → live mode. Only flip after you've verified a full test run.
DRY_RUN=true

# ── Server ────────────────────────────────────────────
PORT=8787

# ── Security ──────────────────────────────────────────
# Random secret for the /api/spin admin endpoint.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=generate_a_random_secret_here

# Comma-separated list of allowed frontend origins (no trailing slash).
# Example: https://cypher-wheel.vercel.app
ALLOWED_ORIGINS=https://cypher-wheel.vercel.app
