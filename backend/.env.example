# ── Network ───────────────────────────────────────────────
# Helius RPC URL (get a free key at helius.dev). Used for snapshots + buyback.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Token ─────────────────────────────────────────────────
# Your Pump.fun token mint address (paste right after launch).
TOKEN_MINT=YOUR_TOKEN_MINT_ADDRESS

# ── Wallets / exclusions ──────────────────────────────────
# Prize-pool wallet that holds + pays out the SOL pot.
# Base58 secret key (the string Phantom exports). KEEP THIS SECRET.
POOL_WALLET_SECRET=YOUR_BASE58_SECRET_KEY

# Comma-separated addresses that must NEVER win or count as holders:
# bonding curve / Raydium LP, creator wallet, treasury, CEX, etc.
# The pool wallet's own address is auto-excluded.
EXCLUDED_ADDRESSES=

# ── Raffle config ─────────────────────────────────────────
# Seconds between spins.
ROUND_INTERVAL_SECONDS=3600

# Minimum token balance (UI units) to qualify for a ticket.
MIN_BALANCE=1000

# Weighting curve: "sqrt" (recommended) | "linear" | "tiered"
WEIGHTING=sqrt

# % of the SOL pool spent on buyback before payout (0-100).
BUYBACK_PERCENT=20

# What happens to bought-back tokens: "burn" | "pool"
BUYBACK_MODE=burn

# ── Safety ────────────────────────────────────────────────
# DRY_RUN=true  -> simulate buyback + payout, move NO real funds. START HERE.
# DRY_RUN=false -> live transactions. Only flip when you've verified everything.
DRY_RUN=true

PORT=8787
